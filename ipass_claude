#---multi logger function to create multiple logs-------
def setup_logger(name, log_file, level=logging.INFO):
    """To setup as many loggers as you want"""
    handler = logging.FileHandler(log_file)
    handler.setFormatter(formatter)
    logger = logging.getLogger(name)
    logger.setLevel(level)
    logger.addHandler(handler)
    return logger

#---Escape special characters in string-------
def escape_string(string_to_escape):
    """Escape special characters in string.

    NOTE (FIX-1): The previous version replaced '"' with '%22' (URL-percent-encoding).
    That is only correct for URL query parameters. These values are placed inside a
    JSON body that is serialised by json.dumps(), which already escapes '"' to '\"'
    automatically. Applying %22 before json.dumps() caused ServiceNow to receive
    the literal text %22 instead of a double-quote character.
    """
    if string_to_escape is None:
        string_to_escape = ""
    # DO NOT add replace('"', '%22') or replace('"', '\\"') here.
    # json.dumps() will handle the correct JSON escaping of '"' exactly once.
    return string_to_escape

#---Escape special characters in topic string-------
def topic_escape_string(string_to_escape):
    """Escape special characters in topic string.
    This function is used exclusively for URL path/topic segments, so
    percent-encoding is correct here.
    """
    if string_to_escape is None:
        string_to_escape = ""
    string_to_escape = string_to_escape.replace('*','%2A')
    string_to_escape = string_to_escape.replace('+','%2B')
    string_to_escape = string_to_escape.replace(',','%2C')
    string_to_escape = string_to_escape.replace('!','%21')
    string_to_escape = string_to_escape.replace('/','%2F')
    string_to_escape = string_to_escape.replace('.','%2E')
    return string_to_escape

def escape_string_desc_fix(string_to_escape):
    """Strip control characters from description/short-description fields.

    NOTE (FIX-2): Do NOT add any replacement for '"' in this function.
    The values produced here are assigned directly into a Python dict and then
    passed through json.dumps() in send_iPaaS(). json.dumps() will correctly
    escape '"' to '\"' inside the JSON string. Any manual pre-escaping of '"'
    to '\"' before json.dumps() results in double-escaping: json.dumps() then
    also escapes the backslash, producing '\\"', which is invalid JSON and
    causes a parse error at the API gateway.

    NOTE (FIX-3): The original code used re.sub(r"\b", "", s). In a regex
    pattern, \b is a zero-width word-boundary assertion, NOT the backspace
    character (0x08). That line was a silent no-op. Corrected to r"\x08".
    """
    if string_to_escape is None:
        return ""
    s = re.sub(r"\r", "", string_to_escape)
    s = re.sub(r"\n", "", s)
    s = re.sub(r"\f", "", s)
    s = re.sub(r"\x08", "", s)   # FIX-3: \x08 = actual backspace; original \b was a no-op
    s = re.sub(r"\t", " ", s)
    return s

