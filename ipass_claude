class IPaaSAlert(CustomGroupActionBase):
    def __init__(self, settings):
        super(IPaaSAlert, self).__init__(settings, logger)

    def add_entry_in_kvstore(self, group_id, method_type):
        try:
            logger.info("add_entry_in_kvstore method")
            date_object = datetime.datetime.today()
            created_date = date_object.strftime("%Y-%m-%d %H:%M:%S")
            payload = '{"episode_id":"' + group_id + '", "date_created":"' + created_date + '", "method_type":"' + method_type + '"}'
            last_exception = None
            for kv_prefix_url in kvstore_url_prefix_array:
                try:
                    kv_url = kv_prefix_url + kvstore_url
                    res = requests.post(kv_url, headers = kvstore_headers, data = payload, auth = HTTPBasicAuth(kvstore_userid, kvstore_passwd), verify=False, timeout=10)
                    respStatus = int(res.status_code)
                    logger.info("response status in add_entry_in_kvstore")
                    if 200 <= respStatus < 300:
                        return True
                    logger.warning("add_entry_in_kvstore received non-success status=%d for url=%s" % (respStatus, kv_url))
                except requests.exceptions.RequestException as e:
                    last_exception = e
                    logger.warning("add_entry_in_kvstore failed for url=%s error=%s" % (kv_prefix_url, str(e)))
            if last_exception is not None:
                raise last_exception
            return False
        except:
            logger.error("error in Catch add_entry_in_kvstore")
            logger.error(sys.exc_info())
            return False

    def read_entry_from_kvstore(self, group_id):
        try:
            logger.info("read_entry_from_kvstore method")
            last_exception = None
            for kv_prefix_url in kvstore_url_prefix_array:
                fileData = []
                try:
                    kv_url = kv_prefix_url + kvstore_url
                    res = requests.get(kv_url, headers = kvstore_headers, auth = HTTPBasicAuth(kvstore_userid, kvstore_passwd), verify=False, timeout=10)
                    respStatus = int(res.status_code)
                    logger.info("response status in read_entry_from_kvstore")
                    if not 200 <= respStatus < 300:
                        logger.warning("read_entry_from_kvstore received non-success status=%d for url=%s" % (respStatus, kv_url))
                        continue
                    respContent = json.loads(res.content)
                    for value in respContent:
                        if "date_created" not in value:
                            value["date_created"] = ""
                        if "method_type" not in value:
                            value["method_type"] = ""
                        if "episode_id" not in value:
                            value["episode_id"] = ""
                        line = str(value["date_created"] + " request_type=" + value["method_type"] +",itsi_group_id=" + value["episode_id"])
                        fileData.append(line)
                    return fileData
                except requests.exceptions.RequestException as e:
                    last_exception = e
                    logger.warning("read_entry_from_kvstore failed for url=%s error=%s" % (kv_prefix_url, str(e)))
            if last_exception is not None:
                raise last_exception
            return []
        except:
            logger.error("error in catch read_entry_frm_kvstore")
            logger.error(sys.exc_info())
            return []

    def check_retry_index_and_add_comment(self, group_id,requestType,itsi_episode,errorComment,fail_wait_flag):
        commentTextToUpdate = ""
        try:
            if fail_wait_flag == "_FAILED":
                fileData = self.read_entry_from_kvstore(group_id)
                logger.info("check_retry_index_and_add_comment method")
                dateObj = datetime.datetime.today()
                todaysDateStr = dateObj.strftime("%Y-%m-%d")
                retryCounter = 0
                requestType = requestType + "_FAILED"
                for line in fileData:
                    if group_id in line and todaysDateStr in line and requestType in line:
                        retryCounter += 1
                tempCounter = retryCounter+1
                commentTextToUpdate = errorComment + " count=(" + str(tempCounter)+ ")"
                if retryCounter == 2:
                    commentTextToUpdate += ". Three times failed, no more retry."
            else:
                commentTextToUpdate = errorComment
                logger.info("if not failed check_retry_index_and_add_comment")
                itsi_episode.create_comment(group_id, commentTextToUpdate)
        except:
            logger.error("error in catch check_retry_index_and_add_comment")
            logger.error(sys.exc_info())

    def send_iPaaS(self, ipassUrl, apiHeaders, message, requestType, itsiGroupId,  itsi_episode):
        logger.info("sending message to aiops outbound")
        respContent = ""
        returnValue = ""
        try:
            logger.info('calling iPaaS rest api : ' + requestType)
            respStatus = 0
            respContent = ""
            if isinstance(message, (dict, list)):
                # json.dumps() correctly escapes all JSON-special characters,
                # including '"' -> '\"'. No manual pre-escaping of '"' should
                # be done before this point. See FIX-1 and FIX-2 in the header.
                message = json.dumps(message)
            else:
                message = re.sub(r"\r","", message)
                message = re.sub(r"\n","", message)
                message = re.sub(r"\f","", message)
                message = re.sub(r"\x08","", message)  # FIX-3: was r"\b" (no-op word boundary)
                message = re.sub(r"\t"," ", message)
                regex = r"[^a-zA-Z0-9!@#$%\^&*()\\ --\+=\[\]\{\}\|:;\"'<>?/.,\_]+"
                message = re.sub(regex,"", message)
            logger.info(ipassUrl)
            logger.info(message)
            logger.info(str(apiHeaders))
            if requestType == "PATCH":
                res = requests.patch(ipassUrl, data = message, headers = apiHeaders, verify=False)
                respStatus = int(res.status_code)
                respContent = str(res.content.decode("utf-8"))
            else:
                logger.info('aiops requests post method call')
                res = requests.post(ipassUrl, data = message, headers = apiHeaders, verify=False)
                logger.info('requests post executed')
                respStatus = int(res.status_code)
                respContent = str(res.content.decode("utf-8"))
            logger.info('aiops response status_code : ' + str(respStatus))
            logger.info('aiops response content : ' + respContent)
            if 200 <= respStatus < 300:
                logger.info('aiops message sent, HTTP status=%d' % respStatus)
                if requestType != "PATCH":
                    incMatch = re.search(r'"messageId"\s*:\s*"(.*?)"',respContent)
                    if incMatch:
                        returnValue = incMatch.group(1)
                        self.add_entry_in_kvstore(itsiGroupId,"POST_SUCCESS")
                        episode_logger.info("itsi_group_id=" + itsiGroupId)
                    if returnValue == "":
                        self.check_retry_index_and_add_comment(itsiGroupId,requestType,itsi_episode,"Calling to aiops Failed. Sending to retry index.","_FAILED")
                        retry_logger.info("ipass_to_splunk_ack,request_type=" +requestType +",itsi_group_id=" + itsiGroupId)
                        self.add_entry_in_kvstore(itsiGroupId, requestType + "_FAILED")
                        return False, returnValue
                return True, returnValue
            else:
                self.check_retry_index_and_add_comment(itsiGroupId,requestType,itsi_episode,"Calling to iPaaS Failed. Sending to retry index.","_FAILED")
                retry_logger.info("ipass_to_splunk_ack,request_type=" +requestType +",itsi_group_id=" + itsiGroupId)
                self.add_entry_in_kvstore(itsiGroupId, requestType + "_FAILED")
                logger.error('Failed to send aiops message, HTTP status=%d' % respStatus)
        except Exception as e:
            logger.info('failed to send aiops custom action alert message: %s' % str(e))
        return False, returnValue

