                        companyName = "AH"
                        state = "Resolved"
                        resolutionDescription = "Incident automatically resolved by SPLUNK, as the incident context is no more valid"
                        resolutionMethod = "Solved - By User"
                        ipassUrl = ipaasUpdateUrl + sys_id + '?uuid=' + uuidNo + "&companyName=" + companyName
                        incidentPayload = {
                            "state": state,
                            "resolutionDescription": resolutionDescription,
                            "resolutionMethod": resolutionMethod
                        }

                    #-------Service Alert Restored and Update WorkNotes in ServiceNow since ticket was assigned to person-----
                    elif inc_worknotes == "Upd":
                        logger.info("Inside IF - PATCH Payload - Alert impact to  Update WorkNotes =>---" + str(group_id))
                        companyName = "AH"
                        worknotesUpdate = "Service Alert Restored (SPLUNK analysis), hence updating the ticket work notes, please take care and close"
                        ipassUrl = ipaasUpdateUrl + sys_id + '?uuid=' + uuidNo + "&companyName=" + companyName
                        incidentPayload = {
                            "workLogDescription": worknotesUpdate
                        }

                    #-------Alert full description updates to ticket in ServiceNow-----
                    else:
                        logger.info("Inside IF - PATCH Payload - Normal Update Ticket WorkNotes =>---" + str(group_id))
                        companyName = "AH"
                        ipassUrl = ipaasUpdateUrl + sys_id + '?uuid=' + uuidNo + "&companyName=" + companyName
                        incidentPayload = {
                            "workLogDescription": fullDescription
                            # fullDescription already has control chars stripped by escape_string_desc_fix().
                            # Any '"' in fullDescription will be correctly escaped to '\"' by
                            # json.dumps() inside send_iPaaS(). Do NOT pre-escape it here.
                        }

                elif requestType == 'POST':
                    logger.info("Inside POST Payload Normal POST Request => "  + str(group_id))
                    ipassUrl = ipaasIncCreateUrl
                    incidentPayload = {
                        "body": {
                            "companyName": companyName,
                            "fullDescription": fullDescription,
                            # fullDescription and shortDescription carry raw '"' characters.
                            # json.dumps() in send_iPaaS() will produce valid JSON with '\"'.
                            # ServiceNow then receives the original '"' character. (FIX-1, FIX-2)
                            "shortDescription": shortDescription,
                            "impact": impactValue,
                            "impactedCi": impactedCi,
                            "urgency": urgencyValue,
                            "correlationId": group_id,
                            "externalSystem": externalSystem,
                            "assigneeGroup": assigneeGroup,
                            "category": category,
                            "subCategory": subCategory,
                            "contactType": contactType,
                            "requestedFor": splunkUser,
                            "customerShortname": customerShortname,
                            "ipAddress": ipAddress,
                            "systemPlatform": systemPlatform,
                            "alertId": alertId,
                            "alertType": alertType,
                            "alertCreatedDate": alertCreatedDate,
                            "correlationFlag": "",
                            "suppressionFlag": "",
                            "deviceType": deviceType,
                            "modelType": modelType,
                            "modelClass": modelClass,
                            "memoryThreshold": memoryThreshold,
                            "cpuThreshold": cpuThreshold,
                            "diskName": diskName,
                            "serviceName": serviceName,
                            "service": service,
                            "serviceOffering": serviceOffering
                        },
                        "header": {
                            "topic": topic,
                            "applicationId": applicationId
                        }
                    }

                # Send message to iPaaS
                resp =  self.send_iPaaS(ipassUrl, apiHeaders, incidentPayload, requestType, group_id, itsi_episode )
                if resp[0]:
                    commentText = "Update Work-Notes request sent to ServiceNow"
                    if requestType == "POST":
                        logger.info("episode_id:"+group_id+" message_id:" + resp[1])
                        commentText = "Incident Creation request successfully sent to Int-HUB-ServiceNow"
                        updData = itsi_episode.update_status([group_id],"1")
                        logger.info("episode status updated")
                        logger.info(updData)
                    itsi_episode.create_comment(group_id, commentText)
                    logger.info("Comment Added in Episode")
                    logger.info(commentText)
                else:
                    itsi_episode.create_comment(group_id, 'Failed to send ACK message back to AIOps!')
        except Exception as e:
            logger.error('Failed to execute AIOps Custom Action Alerts: %s' % e.message)
            logger.exception(e)
            sys.exit(1)

